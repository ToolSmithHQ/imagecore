{
  "name": "imagecore",
  "private": true,
  "workspaces": [
    "packages/types",
    "packages/native",
    "packages/web",
    "packages/files"
  ],
  "scripts": {
    "build:types": "cd packages/types && npm run build",
    "build:wasm": "cd packages/web && npm run build:wasm",
    "build": "npm run build:types",
    "test:core": "cd packages/core && cmake --build build --target test",
    "clean": "rm -rf packages/*/dist packages/core/build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
