{
  "name": "@toolsmith/imagecore-native",
  "version": "0.1.0",
  "description": "Native C/C++ image processing for React Native via JSI — lossless JPEG ops, full format support",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "ios",
    "android",
    "plugin"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "expo": ">=52.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "dependencies": {
    "@toolsmith/imagecore-types": "0.1.0"
  },
  "expo": {
    "configPlugin": "./plugin/index.js"
  },
  "codegenConfig": {
    "name": "ImageCoreSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  }
}
